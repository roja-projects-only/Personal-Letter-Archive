DATABASE_URL=postgresql://user:pass@localhost:5432/letter_archive
JWT_SECRET=replace_with_long_random_string
JWT_EXPIRES_IN=7d
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token
FRONTEND_URL=http://localhost:5173
PORT=3000
NODE_ENV=development

# Used by prisma/seed.js (optional — defaults below for local dev)
SEED_AUTHOR_EMAIL=you@example.com
SEED_AUTHOR_PASSWORD=change-me
SEED_RECIPIENT_NAME=Her Name
SEED_RECIPIENT_PIN=1234
