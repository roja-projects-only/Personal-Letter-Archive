# Development: leave empty — Vite proxies /api to localhost:3000.
# Production with Vercel /api proxy (recommended, fixes iOS Safari):
#   Leave empty. Set the Railway URL in vercel.json instead (see README).
# Production without Vercel proxy (cross-origin, broken in iOS Safari):
#   Set to the full backend URL, e.g. https://your-api.up.railway.app
VITE_API_URL=
